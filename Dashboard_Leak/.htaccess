# Dashboard Leak — Apache Rewrite Rules for PHP API
# ===================================================
# Rewrite /api/* requests to api.php while preserving PATH_INFO
# Static files (index.html, manage.html, etc.) served directly by Apache

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Preserve path info for PHP routing
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^api/(.*)$ api.php [QSA,L]
</IfModule>

# ─── PHP settings for large file uploads ─────────────────────────────────
# Prevent HTML errors from corrupting JSON API responses
php_flag display_errors Off
php_flag html_errors Off
php_value log_errors On

# Allow uploading many files at once (default max_file_uploads = 20)
php_value max_file_uploads 100
php_value upload_max_filesize 50M
php_value post_max_size 200M
php_value max_execution_time 600
php_value memory_limit 512M

# UTF-8 support
AddDefaultCharset UTF-8
AddType application/json .json

# Performance: enable gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/json text/html text/plain text/xml text/css application/javascript
</IfModule>
